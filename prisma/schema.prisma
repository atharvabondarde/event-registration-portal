generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  email    String @id @map("_id")
  password String
  name     String
  role     String
}

model Event {
  id            String  @id @map("_id")
  title         String
  description   String
  category      String
  price         Float
  capacity      Int
  registered    Int
  date          String
  time          String
  locationType  String
  location      String
  duration      String?
  gradient      String?
  customFields  Json?
  schedule      Json?
}

model Registration {
  id           String  @id @map("_id")
  eventId      String
  email        String
  registeredAt String
  pricePaid    Float?
  checkedIn    Boolean
  customData   Json?
}

model Log {
  id        String @id @map("_id")
  timestamp String
  type      String
  message   String
}
